<% content_for :title, "Results" %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1">Results</h1>
  </div>

  <% if authenticated? %>
    <%= link_to "New result", new_result_path, class: "btn btn-primary" %>
  <% end %>
</div>

<div class="row g-3 mb-2">
  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Current streak</div>
        <div class="fs-4 fw-semibold"><%= pluralize(@statistics[:current_streak][:count], @statistics[:current_streak][:type].to_s.capitalize) %></div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Longest winning streak</div>
        <div class="">
          <span class="fs-4 fw-bold pe-1">
          <%= @statistics[:longest_winning_streak][:length] %>
          </span>
          <span class="badge bg-light text-dark border">
            <%= "#{@statistics[:longest_winning_streak][:start_number]} – #{@statistics[:longest_winning_streak][:end_number]}" %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Longest losing streak</div>
        <div class="">
          <span class="fs-4 fw-bold" pe-1>
          <%= @statistics[:longest_losing_streak][:length] %>
          </span>
          <span class="badge bg-light text-dark border">
            <%= "#{@statistics[:longest_losing_streak][:start_number]} – #{@statistics[:longest_losing_streak][:end_number]}" %>
          </span>
        </div>
      </div>
    </div>
  </div>

</div>

<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Highest score</div>
          <span class="fs-4 fw-bold" pe-1>
          <%= format_score(@statistics[:highest_score][:score]) %>
          </span>
          <span class="badge bg-light text-dark border">
            <%= @statistics[:highest_score][:number] %>
          </span>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Lowest score</div>
          <span class="fs-4 fw-bold" pe-1>
          <%= format_score(@statistics[:lowest_score][:score]) %>
          </span>
          <span class="badge bg-light text-dark border">
            <%= @statistics[:lowest_score][:number] %>
          </span>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Average Score</div>
        <div class="fw-semibold"><%= format_score(@statistics[:average_score]) %></div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-2">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Win Rate</div>
        <div class="fw-semibold"><%= format_score(@statistics[:win_rate]) %></div>
      </div>
    </div>
  </div>
</div>

<% if @results.any? %>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th scope="col">#</th>
            <th scope="col">Score</th>
            <th scope="col">Position</th>
            <th scope="col">Comment</th>
            <% if authenticated? %>
              <th scope="col" class="text-end">Actions</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @results.each do |result| %>
            <tr id="<%= dom_id(result) %>">
              <td class="fw-semibold"><%= result.number %></td>
              <td><%= format_score(result.score) %></td>
              <td>
                <% if result.win? %>
                  <%= tag.i(class: %w[bi bi-trophy-fill text-warning]) %>
                <% else %>
                  <%= result.position %>
                <% end %>
              </td>
              <td class="text-muted"><%= result.comment.presence || "—" %></td>
              <% if authenticated? %>
                <td class="text-end text-nowrap">
                  <%= link_to image_tag('edit.png', class: "table_icon"), edit_result_path(result), class: 'me-md-1' %>             
                  <%= link_to image_tag('dustbin.webp', class: "table_icon"), result, data: { turbo_method: :delete, turbo_confirm: "Delete result ##{result.number}?" }%>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <p class="text-muted mb-0">No results yet.</p>
      <% if authenticated? %>
        <%= link_to "Add the first result", new_result_path, class: "btn btn-primary mt-3" %>
      <% end %>
    </div>
  </div>
<% end %>
