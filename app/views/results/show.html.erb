<% content_for :title, "Result ##{@result.number}" %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1">Result #<%= @result.number %></h1>
    <p class="text-muted mb-0">
      <%= @result.win? ? "Win" : "Loss" %> with a score of <%= format_score(@result.score) %>.
    </p>
  </div>

  <div class="d-flex gap-2">
    <%= link_to "Back to results", results_path, class: "btn btn-outline-secondary" %>
    <%= link_to "Edit", edit_result_path(@result), class: "btn btn-primary" %>
    <%= button_to "Delete", @result, method: :delete, class: "btn btn-outline-danger", form: { data: { turbo_confirm: "Delete result ##{@result.number}?" } } %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <%= render @result %>
  </div>
</div>
